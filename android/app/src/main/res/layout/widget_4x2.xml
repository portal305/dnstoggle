<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:baselineAligned="false"
    android:orientation="horizontal"
    android:padding="8dp">

    <!-- Left side: Status and Toggle -->
    <LinearLayout
        android:id="@+id/widget_left_section"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/widget_icon_4x2"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_shield" />

        <TextView
            android:id="@+id/widget_status_4x2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="INACTIVE"
            android:textColor="@color/widget_text_secondary"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_server_name_4x2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="AdGuard DNS"
            android:textColor="@color/widget_text_primary"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_server_hostname_4x2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="dns.adguard-dns.com"
            android:textColor="@color/widget_text_secondary"
            android:textSize="10sp" />
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:layout_marginVertical="12dp"
        android:background="@color/surfaceVariant" />

    <!-- Right side: Server List -->
    <ListView
        android:id="@+id/widget_server_list"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1.5"
        android:divider="@android:color/transparent"
        android:dividerHeight="0dp"
        android:paddingStart="8dp" />

</LinearLayout>
